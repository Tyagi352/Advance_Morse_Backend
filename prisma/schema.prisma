generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model chat_messages {
  id                                      Int       @id @default(autoincrement())
  sender_id                               Int
  recipient_id                            Int
  morse                                   String
  decoded_text                            String
  created_at                              DateTime? @default(now()) @db.Timestamp(6)
  file_path                               String?
  file_content                            String?
  language                                String?   @default("english") @db.VarChar(50)
  users_chat_messages_recipient_idTousers users     @relation("chat_messages_recipient_idTousers", fields: [recipient_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_chat_messages_sender_idTousers    users     @relation("chat_messages_sender_idTousers", fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model encoded_files {
  id            Int       @id @default(autoincrement())
  user_id       Int
  original_name String    @db.VarChar(255)
  file_name     String    @db.VarChar(255)
  file_path     String?
  file_type     String?   @default("encoded") @db.VarChar(50)
  is_viewable   Boolean?  @default(true)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  file_content  String?
  users         users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model shared_files {
  id                                     Int       @id @default(autoincrement())
  sender_id                              Int
  recipient_id                           Int
  file_name                              String    @db.VarChar(255)
  file_path                              String?
  shared_at                              DateTime? @default(now()) @db.Timestamp(6)
  status                                 String?   @default("active") @db.VarChar(50)
  expires_at                             DateTime? @db.Timestamp(6)
  language                               String?   @default("english") @db.VarChar(50)
  file_content                           String?
  users_shared_files_recipient_idTousers users     @relation("shared_files_recipient_idTousers", fields: [recipient_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_shared_files_sender_idTousers    users     @relation("shared_files_sender_idTousers", fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  id                                              Int             @id @default(autoincrement())
  username                                        String          @unique @db.VarChar(255)
  email                                           String          @unique @db.VarChar(255)
  password_hash                                   String
  fernet_key                                      String
  public_key                                      String?
  chat_messages_chat_messages_recipient_idTousers chat_messages[] @relation("chat_messages_recipient_idTousers")
  chat_messages_chat_messages_sender_idTousers    chat_messages[] @relation("chat_messages_sender_idTousers")
  encoded_files                                   encoded_files[]
  shared_files_shared_files_recipient_idTousers   shared_files[]  @relation("shared_files_recipient_idTousers")
  shared_files_shared_files_sender_idTousers      shared_files[]  @relation("shared_files_sender_idTousers")
}
